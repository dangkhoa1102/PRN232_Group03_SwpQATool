## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Dd]ebug/
[Rr]elease/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bin/
obj/
out/

# .NET Core / ASP.NET Core
project.lock.json
project.fragment.lock.json
artifacts/

# Visual Studio / VS Code
.vs/
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# Logs
*.log
logs/

# OS generated files
.DS_Store
Thumbs.db

# Rider
.idea/

# NuGet
*.nupkg
*.snupkg
packages/
!**/packages/build/

# Local app settings override
appsettings.Local.json

# Test / coverage
TestResults/
coverage/
*.coverage
*.coveragexml

# Dotnet tools
.dotnet/

# Node (if added later)
node_modules/
